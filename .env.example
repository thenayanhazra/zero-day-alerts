# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_TO=you@example.com,colleague@example.com
EMAIL_FROM=alerts@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=20

# ── SMS / WhatsApp (Twilio) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+15551234567
SMS_TO=+15559876543
WHATSAPP_TO=+15559876543

# ── Alert policy ──────────────────────────────────────────────────────────────
MIN_SEVERITY=HIGH
ZERO_DAY_ONLY=true
POLL_INTERVAL_SECONDS=300

# ── Sources ───────────────────────────────────────────────────────────────────
ENABLE_NVD=true
ENABLE_CISA_KEV=true
ENABLE_GITHUB_ADVISORIES=true
NVD_API_KEY=
GITHUB_TOKEN=

# ── Polling windows ───────────────────────────────────────────────────────────
NVD_LOOKBACK_HOURS=24
GITHUB_LOOKBACK_HOURS=24
CURSOR_OVERLAP_MINUTES=10

# ── Storage ───────────────────────────────────────────────────────────────────
DB_PATH=data/alerts.db
